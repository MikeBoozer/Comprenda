# Secrets and environment
.env
.env.*
*.secret
*.key

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.venv/
venv/
env/
ENV/
.ipynb_checkpoints/
.mypy_cache/
